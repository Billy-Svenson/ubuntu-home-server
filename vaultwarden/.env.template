# Generate admin token: openssl rand -base64 48
# Then hash it:        sudo docker exec -it vaultwarden /vaultwarden hash
# Wrap hash in single quotes — it contains $ characters
ADMIN_TOKEN='YOUR_ARGON2_HASH'

SIGNUPS_ALLOWED=false

# Gmail App Password (Google Account → Security → 2FA → App passwords)
# Enter WITHOUT spaces
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_SECURITY=starttls
SMTP_USERNAME=YOUR_GMAIL
SMTP_PASSWORD=YOUR_GMAIL_APP_PASSWORD
SMTP_FROM=YOUR_GMAIL
